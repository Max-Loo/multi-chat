/**
 * BottomNav 组件测试
 *
 * 测试三个导航项渲染、路由导航、激活状态高亮、仅在Mobile模式显示
 */

import { describe, it, expect, afterEach, vi } from 'vitest';
import { render, screen, cleanup } from '@testing-library/react';
import { MemoryRouter } from 'react-router-dom';

// Mock react-router-dom
const mockNavigate = vi.fn();
vi.mock('react-router-dom', async () => ({
  useNavigate: () => mockNavigate,
  useLocation: () => ({
    pathname: '/chat',
  }),
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  ...(await vi.importActual('react-router-dom')) as any,
}));

// Mock ResponsiveContext
vi.mock('@/context/ResponsiveContext', () => ({
  useResponsive: () => ({
    isMobile: true,
    layoutMode: 'mobile',
  }),
}));

// Mock react-i18next
vi.mock('react-i18next', () => ({
  useTranslation: () => ({
    t: (key: string) => {
      const translations: Record<string, string> = {
        'nav.chat': '聊天',
        'nav.model': '模型',
        'nav.setting': '设置',
      };
      return translations[key] || key;
    },
  }),
}));

// Mock navigation配置
vi.mock('@/config/navigation', () => ({
  NAVIGATION_ITEMS: [
    {
      id: 'chat',
      path: '/chat',
      i18nKey: 'nav.chat',
      IconComponent: () => <svg data-testid="chat-icon" />,
      theme: {
        base: 'text-blue-400',
        active: 'bg-blue-100 text-blue-500',
        inactive: 'hover:text-blue-500 hover:bg-blue-100',
      },
    },
    {
      id: 'model',
      path: '/model',
      i18nKey: 'nav.model',
      IconComponent: () => <svg data-testid="model-icon" />,
      theme: {
        base: 'text-emerald-400',
        active: 'bg-emerald-100 text-emerald-500',
        inactive: 'hover:text-emerald-500 hover:bg-emerald-100',
      },
    },
    {
      id: 'setting',
      path: '/setting',
      i18nKey: 'nav.setting',
      IconComponent: () => <svg data-testid="setting-icon" />,
      theme: {
        base: 'text-violet-400',
        inactive: 'hover:text-violet-500 hover:bg-violet-100',
        active: 'bg-violet-100 text-violet-500',
      },
    },
  ],
}));

import { BottomNav } from '@/components/BottomNav';

// Mock ResponsiveContext
vi.mock('@/context/ResponsiveContext', () => ({
  useResponsive: () => ({
    isMobile: true,
    layoutMode: 'mobile',
  }),
}));

// Mock react-i18next
vi.mock('react-i18next', () => ({
  useTranslation: () => ({
    t: (key: string) => {
      const translations: Record<string, string> = {
        'nav.chat': '聊天',
        'nav.model': '模型',
        'nav.setting': '设置',
      };
      return translations[key] || key;
    },
  }),
}));

// Mock navigation配置
vi.mock('@/config/navigation', () => ({
  NAVIGATION_ITEMS: [
    {
      id: 'chat',
      path: '/chat',
      i18nKey: 'nav.chat',
      IconComponent: () => <svg data-testid="chat-icon" />,
      theme: {
        base: 'text-blue-400',
        active: 'bg-blue-100 text-blue-500',
        inactive: 'hover:text-blue-500 hover:bg-blue-100',
      },
    },
    {
      id: 'model',
      path: '/model',
      i18nKey: 'nav.model',
      IconComponent: () => <svg data-testid="model-icon" />,
      theme: {
        base: 'text-emerald-400',
        active: 'bg-emerald-100 text-emerald-500',
        inactive: 'hover:text-emerald-500 hover:bg-emerald-100',
      },
    },
    {
      id: 'setting',
      path: '/setting',
      i18nKey: 'nav.setting',
      IconComponent: () => <svg data-testid="setting-icon" />,
      theme: {
        base: 'text-violet-400',
        inactive: 'hover:text-violet-500 hover:bg-violet-100',
        active: 'bg-violet-100 text-violet-500',
      },
    },
  ],
}));

describe('BottomNav 组件', () => {
  afterEach(() => {
    cleanup();
    vi.clearAllMocks();
  });

  describe('基础渲染', () => {
    it('应该在移动端模式正确渲染', () => {
      render(
        <MemoryRouter initialEntries={['/chat']}>
          <BottomNav />
        </MemoryRouter>
      );

      const nav = screen.getByRole('navigation');
      expect(nav).toBeInTheDocument();
    });

    it('应该渲染三个导航项', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      expect(screen.getByText('聊天')).toBeInTheDocument();
      expect(screen.getByText('模型')).toBeInTheDocument();
      expect(screen.getByText('设置')).toBeInTheDocument();
    });

    it('应该渲染所有图标', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      expect(screen.getByTestId('chat-icon')).toBeInTheDocument();
      expect(screen.getByTestId('model-icon')).toBeInTheDocument();
      expect(screen.getByTestId('setting-icon')).toBeInTheDocument();
    });
  });

  describe('响应式行为', () => {
    it('仅在移动端模式下显示', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const nav = screen.getByRole('navigation');
      expect(nav).toBeInTheDocument();
    });
  });

  describe('路由导航', () => {
    it('点击聊天按钮应该导航到 /chat', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const chatButton = screen.getByText('聊天');
      chatButton.click();

      expect(mockNavigate).toHaveBeenCalledWith('/chat');
    });

    it('点击模型按钮应该导航到 /model', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const modelButton = screen.getByText('模型');
      modelButton.click();

      expect(mockNavigate).toHaveBeenCalledWith('/model');
    });

    it('点击设置按钮应该导航到 /setting', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const settingButton = screen.getByText('设置');
      settingButton.click();

      expect(mockNavigate).toHaveBeenCalledWith('/setting');
    });
  });

  describe('激活状态高亮', () => {
    it('当前路径应该高亮显示', () => {
      // mock location.pathname 为 '/chat'
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      // 找到聊天按钮并检查是否激活
      const buttons = screen.getAllByRole('button');
      const chatButton = buttons.find((btn) => btn.textContent?.includes('聊天'));
      expect(chatButton).toBeInTheDocument();
      // 激活状态应该有特定的类名
      expect(chatButton).toHaveClass('bg-blue-100');
    });

    it('非激活路径应该使用非激活样式', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      // 模型和设置按钮应该是非激活状态
      const buttons = screen.getAllByRole('button');
      const modelButton = buttons.find((btn) => btn.textContent?.includes('模型'));
      expect(modelButton).toBeInTheDocument();
    });
  });

  describe('样式和布局', () => {
    it('应该有正确的固定定位类', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const nav = screen.getByRole('navigation');
      expect(nav).toHaveClass('border-t', 'bg-background', 'h-16');
    });

    it('应该使用flex布局均匀分布导航项', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const nav = screen.getByRole('navigation');
      const containerDiv = nav.querySelector('div');
      expect(containerDiv).toHaveClass('flex', 'items-center', 'justify-around');
    });

    it('导航项应该有正确的主题样式', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const buttons = screen.getAllByRole('button');
      const chatButton = buttons.find((btn) => btn.textContent?.includes('聊天'));

      expect(chatButton).toHaveClass('text-blue-400');
    });
  });

  describe('可访问性', () => {
    it('导航按钮应该有正确的title属性', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const chatButton = screen.getByTitle('聊天');
      const modelButton = screen.getByTitle('模型');
      const settingButton = screen.getByTitle('设置');

      expect(chatButton).toBeInTheDocument();
      expect(modelButton).toBeInTheDocument();
      expect(settingButton).toBeInTheDocument();
    });

    it('激活的页面应该有 aria-current 属性', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      // 找到激活的按钮（当前在/chat页面）
      const buttons = screen.getAllByRole('button');
      const chatButton = buttons.find((btn) => btn.textContent?.includes('聊天'));
      expect(chatButton).toHaveAttribute('aria-current', 'page');
    });
  });

  describe('子路径匹配', () => {
    it('应该在子路径时也高亮父级导航', () => {
      // 修改mock location.pathname为子路径
      vi.doMock('react-router-dom', async () => ({
        useNavigate: () => mockNavigate,
        useLocation: () => ({
          pathname: '/model/create',
        }),
        ...(await vi.importActual('react-router-dom')) as any,
      }));

      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      // 模型按钮应该被高亮（因为 /model/create 以 /model 开头）
      const buttons = screen.getAllByRole('button');
      const modelButton = buttons.find((btn) => btn.textContent?.includes('模型'));
      expect(modelButton).toBeInTheDocument();
    });
  });

  describe('国际化', () => {
    it('应该正确显示翻译后的文本', () => {
      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      expect(screen.getByText('聊天')).toBeInTheDocument();
      expect(screen.getByText('模型')).toBeInTheDocument();
      expect(screen.getByText('设置')).toBeInTheDocument();
    });
  });

  describe('边界情况', () => {
    it('应该处理根路径（不匹配任何导航项）', () => {
      vi.doMock('react-router-dom', async () => ({
        useNavigate: () => mockNavigate,
        useLocation: () => ({
          pathname: '/',
        }),
        ...(await vi.importActual('react-router-dom')) as any,
      }));

      render(
        <MemoryRouter initialEntries=["{"]/chat["{"]}>
          <BottomNav />
        </MemoryRouter>
      );

      const buttons = screen.getAllByRole('button');
      expect(buttons.length).toBe(3);
    });
  });
});
