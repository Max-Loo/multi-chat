    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "1.0.0",
    "fake-indexeddb": "^6.2.5",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "i18next-cli": "^1.49.3",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "oxlint": "^1.51.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.1",
