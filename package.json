    "lucide-react": "^0.577.0",
    "markdown-it": "^14.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.6",
    "react-masonry-css": "^1.0.16",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.7.2",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
