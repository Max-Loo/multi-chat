{
  "name": "multi-chat",
  "version": "0.3.8",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "web:dev": "vite",
    "web:build": "tsc && vite build",
    "web:build:tauri": "tsc && vite build",
    "deploy:gh-pages": "BASE_PATH=/multi-chat/ pnpm web:build && gh-pages -d dist",
    "lint": "oxlint",
    "lint:i18n": "node scripts/check-i18n.js",
    "validate": "npm run lint && npm run lint:i18n",
    "preview": "vite preview",
    "tauri": "tauri",
    "update-version": "node scripts/update-version.js",
    "generate-i18n-types": "node scripts/generate-i18n-types-resources.js",
    "analyze:unused": "knip",
    "prepare": "husky",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest -c vitest.integration.config.ts",
    "test:integration:run": "vitest run -c vitest.integration.config.ts",
    "test:all": "pnpm test:run && pnpm test:integration:run"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.24",
